# Environment Configuration
# Production environment - DO NOT commit this file

# ==========================================
# NODE
# ==========================================
NODE_ENV=production
PORT=3000

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://user:password@prod-db:5432/pasha_tracker_prod
REDIS_URL=redis://prod-redis:6379/0

# ==========================================
# SOLANA
# ==========================================
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_PROD_KEY
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_PROD_KEY
HELIUS_API_KEY=your_prod_helius_key

# ==========================================
# SECURITY
# ==========================================
JWT_SECRET=your-super-secret-production-jwt-key-min-32-chars-long
API_RATE_LIMIT=60

# ==========================================
# MONITORING
# ==========================================
LOG_LEVEL=warn
METRICS_ENABLED=true
METRICS_PORT=9090
SENTRY_DSN=your_sentry_dsn_here

# ==========================================
# FEATURES
# ==========================================
ENABLE_REALTIME=true
ENABLE_HISTORICAL=true
ENABLE_WEBSOCKET=true
ENABLE_BUNDLE_DETECTION=true

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_DELAY_MS=200
MAX_REQUESTS_PER_MINUTE=300
