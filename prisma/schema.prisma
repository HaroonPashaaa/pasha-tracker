generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Wallet {
  id          String   @id @default(uuid())
  address     String   @unique
  firstSeen   DateTime @default(now())
  lastUpdated DateTime @updatedAt
  balance     Decimal  @default(0)
  labels      String[]
  riskScore   Float    @default(0)
  
  // Relations
  transactionsSent     Transaction[] @relation("FromWallet")
  transactionsReceived Transaction[] @relation("ToWallet")
  traces               Trace[]
  
  @@index([address])
  @@index([riskScore])
}

model Transaction {
  id          String   @id @default(uuid())
  signature   String   @unique
  slot        BigInt
  timestamp   DateTime
  
  // Amount info
  amount      Decimal
  tokenType   String   @default("SOL") // SOL, USDC, etc.
  
  // Wallets
  fromAddress String
  toAddress   String
  fromWallet  Wallet   @relation("FromWallet", fields: [fromAddress], references: [address])
  toWallet    Wallet   @relation("ToWallet", fields: [toAddress], references: [address])
  
  // Analysis
  isOffRamp   Boolean  @default(false)
  offRampConfidence Float @default(0)
  exchangeId  String?
  
  @@index([signature])
  @@index([fromAddress])
  @@index([toAddress])
  @@index([timestamp])
  @@index([isOffRamp])
}

model Trace {
  id          String   @id @default(uuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id])
  
  traceType   String   // "backward" or "forward"
  maxDepth    Int
  
  // Results
  originWallet    String?
  destinationWallet String?
  pathLength      Int?
  totalAmount     Decimal?
  
  // JSON data
  hops        Json?
  
  createdAt   DateTime @default(now())
  
  @@index([walletId])
  @@index([createdAt])
}

model ExchangeWallet {
  id          String   @id @default(uuid())
  address     String   @unique
  exchange    String   // Binance, Coinbase, etc.
  walletType  String   // "hot", "cold", "deposit", "withdrawal"
  
  firstSeen   DateTime @default(now())
  lastVerified DateTime?
  
  @@index([address])
  @@index([exchange])
}

model Bundle {
  id          String   @id @default(uuid())
  tokenAddress String
  
  wallets     String[] // Array of wallet addresses
  confidence  Float
  totalVolume Decimal
  
  firstPurchase DateTime
  detectedAt    DateTime @default(now())
  
  @@index([tokenAddress])
  @@index([detectedAt])
}

model ApiCall {
  id          String   @id @default(uuid())
  apiName     String   // "solana-rpc", "binance-api", etc.
  endpoint    String
  statusCode  Int
  duration    Int      // milliseconds
  retryCount  Int      @default(0)
  timestamp   DateTime @default(now())
  
  @@index([apiName])
  @@index([timestamp])
  @@index([statusCode])
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String   // hashed
  apiKey      String   @unique
  
  tier        String   @default("free") // free, pro, enterprise
  rateLimit   Int      @default(100)   // requests per minute
  
  createdAt   DateTime @default(now())
  lastLogin   DateTime?
  
  @@index([apiKey])
  @@index([email])
}