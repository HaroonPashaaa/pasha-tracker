{
  "name": "pasha-tracker",
  "version": "1.0.0",
  "description": "Comprehensive Solana blockchain transaction tracing tool",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "solana",
    "blockchain",
    "forensics",
    "tracing",
    "analytics",
    "cryptocurrency"
  ],
  "author": "Pasha",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.91.0",
    "@prisma/client": "^5.11.0",
    "express": "^4.18.3",
    "ws": "^8.16.0",
    "redis": "^4.6.13",
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "winston": "^3.12.0",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "node-cron": "^3.0.3",
    "bottleneck": "^2.19.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "prisma": "^5.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
