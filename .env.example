# Pasha Tracker Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# SOLANA RPC (Required)
# ==========================================
# Primary RPC endpoint (Helius recommended)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Fallback RPC (optional)
SOLANA_FALLBACK_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API Key (for enhanced APIs)
HELIUS_API_KEY=your_helius_api_key_here

# ==========================================
# DATABASE (Required)
# ==========================================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/pasha_tracker

# Redis connection (for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0

# ==========================================
# EXCHANGE APIs (Optional but recommended)
# ==========================================
# Binance API (for verification)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret

# Coinbase API
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_SECRET=your_coinbase_secret

# Kraken API
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_SECRET=your_kraken_secret

# ==========================================
# RATE LIMITING (Optional - defaults shown)
# ==========================================
# Delay between external API calls (milliseconds)
RATE_LIMIT_DELAY_MS=200

# Maximum retries on rate limit
MAX_RETRIES=3

# Exponential backoff multiplier
BACKOFF_MULTIPLIER=2

# Maximum requests per minute per API
MAX_REQUESTS_PER_MINUTE=300

# ==========================================
# MONITORING & LOGGING
# ==========================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable metrics collection
METRICS_ENABLED=true

# Prometheus metrics port
METRICS_PORT=9090

# ==========================================
# SECURITY
# ==========================================
# JWT secret for API authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API rate limit per IP (requests per minute)
API_RATE_LIMIT=60

# ==========================================
# FEATURE FLAGS
# ==========================================
# Enable real-time indexing
ENABLE_REALTIME=true

# Enable historical backfill
ENABLE_HISTORICAL=true

# Enable bundle detection
ENABLE_CLUSTERING=true

# Enable exchange verification
ENABLE_EXCHANGE_LAYER=true

# ==========================================
# DEVELOPMENT
# ==========================================
# Node environment: development, production
NODE_ENV=development

# Port for API server
PORT=3000

# Enable CORS (set to false in production if behind proxy)
ENABLE_CORS=true

# ==========================================
# TESTING
# ==========================================
# Test database URL (separate from production)
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/pasha_tracker_test

# Use mock data for tests (faster, no API calls)
USE_MOCK_DATA_IN_TESTS=false
